# ─────────────────────────────────────────────────────────────
#  CoinScopeAI — .gitignore (Monorepo)
#  NEVER commit secrets, credentials, or generated artefacts
# ─────────────────────────────────────────────────────────────

# ── Secrets & Credentials (CRITICAL) ─────────────────────────
.env
.env.*
!.env.example
secrets.json
credentials.json
*.key
*.pem
configs/secrets/*
!configs/secrets/.gitkeep

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual Environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.conda/

# ── Node.js / Frontend ───────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
apps/dashboard/dist/
apps/dashboard/.next/

# ── Jupyter Notebooks ─────────────────────────────────────────
.ipynb_checkpoints

# ── Testing & Coverage ────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
htmlcov/

# ── ML Models & Data ──────────────────────────────────────────
*.pkl
*.pickle
*.joblib
*.h5
*.hdf5
*.pt
*.pth
*.onnx
ai/models/saved/
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/features/*
!data/features/.gitkeep
*.csv
*.parquet
*.feather

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── Docker ────────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock

# ── Terraform ─────────────────────────────────────────────────
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/crash.log
infra/terraform/*.tfvars
!infra/terraform/*.tfvars.example

# ── OS / Editor ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Project-specific ──────────────────────────────────────────
# Legacy duplicate engine folders
coinscope_trading_engine 2/
coinscope_trading_engine 3/
coinscope_trading_engine 4/
*.tar.gz
*.zip

# Temporary & generated docs
CLAUDE.md
