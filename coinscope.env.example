# ============================================================
#  CoinScopeAI — Daily Status Check Environment Template
#  Used by: scripts/daily_status_check.py
#           scripts/run_daily_status.sh (cron wrapper)
#
#  Setup:
#    cp coinscope.env.example coinscope.env
#    # Fill in your real values, then:
#    chmod 600 coinscope.env
#
#  NEVER commit coinscope.env — it is covered by .gitignore.
# ============================================================

# ── CoinScopeAI Engine ────────────────────────────────────────────────────────
# URL of the running CoinScopeAI paper-trading engine.
# Default: http://localhost:8001
COINSCOPEAI_BASE_URL=http://localhost:8001

# ── Telegram Notifications ────────────────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram (/newbot).
# 2. Copy the token it gives you into TELEGRAM_BOT_TOKEN.
# 3. Send any message to your bot, then call:
#      curl https://api.telegram.org/bot<TOKEN>/getUpdates
#    and copy the "chat.id" value into TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Binance Futures Testnet (optional) ───────────────────────────────────────
# Required only for the Binance balance / P&L check.
# Get keys at: https://testnet.binancefuture.com
#   Profile → API Key Management → Generate Key
BINANCE_FUTURES_TESTNET_BASE_URL=https://testnet.binancefuture.com
BINANCE_FUTURES_TESTNET_API_KEY=your_futures_testnet_api_key_here
BINANCE_FUTURES_TESTNET_API_SECRET=your_futures_testnet_api_secret_here
