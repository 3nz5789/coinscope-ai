# ============================================================
#  CoinScopeAI — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git. It is already in .gitignore.
# ============================================================

# ── Binance Futures Testnet ──────────────────────────────────
# Get keys at: https://testnet.binancefuture.com
# Register → Profile → API Key Management → Generate Key
BINANCE_FUTURES_TESTNET_API_KEY=your_futures_testnet_api_key_here
BINANCE_FUTURES_TESTNET_API_SECRET=your_futures_testnet_api_secret_here
BINANCE_FUTURES_TESTNET_BASE_URL=https://testnet.binancefuture.com

# ── Binance Spot Testnet ─────────────────────────────────────
# Get keys at: https://testnet.binance.vision (GitHub login required)
BINANCE_SPOT_TESTNET_API_KEY=your_spot_testnet_api_key_here
BINANCE_SPOT_TESTNET_API_SECRET=your_spot_testnet_api_secret_here
BINANCE_SPOT_TESTNET_BASE_URL=https://testnet.binance.vision

# ── Binance Live (Mainnet) — LEAVE BLANK until ready ────────
# Only populate when moving off testnet. Handle with extreme care.
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=

# ── Notion ──────────────────────────────────────────────────
# Get from: https://www.notion.so/my-integrations
# Token starts with "ntn_" or "secret_"
NOTION_TOKEN=ntn_your_notion_integration_token_here
NOTION_EXPORT_INTERVAL=3600
NOTION_DRY_RUN=0

# ── Telegram Alerts ─────────────────────────────────────────
# Get BOT_TOKEN from @BotFather on Telegram
# Get CHAT_ID by messaging your bot and calling getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── CoinScopeAI Engine ──────────────────────────────────────
ENGINE_PORT=8001
ENGINE_HOST=0.0.0.0
LOG_LEVEL=INFO
TESTNET_MODE=true
INITIAL_CAPITAL=10000

# ── Risk Gate ───────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=0.03
MAX_CONSECUTIVE_LOSSES=5
MAX_DRAWDOWN_PCT=0.10
MAX_OPEN_POSITIONS=3
