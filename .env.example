# ============================================================
# CoinScopeAI - environment configuration template
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================
# This file is the canonical source. `.env.template` is retained as an
# alias and will be removed after the validation phase.
# Organized by domain. Leave blank / default where you do not use a feature.

# =====================================================================
# APP
# =====================================================================

# Deployment environment: development | staging | production
APP_ENV=development

# Set to "true" to route trading to Binance Futures Testnet.
# ALWAYS "true" during the validation phase (2026-04-10 .. 2026-04-30).
TESTNET_MODE=true

# Base URL of the CoinScopeAI FastAPI engine (the API on :8001).
COINSCOPEAI_BASE_URL=http://localhost:8001

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Directory for engine logs (relative paths resolve under engine cwd).
LOG_DIR=logs


# =====================================================================
# DATABASE
# =====================================================================

# Application data store. Use SQLite locally, Postgres in staging/prod.
# Examples:
#   sqlite:///coinscope_trades.db
#   postgresql://user:pass@localhost:5432/coinscope
DATABASE_URL=sqlite:///coinscope_trades.db


# =====================================================================
# CACHE / QUEUE (Redis)
# =====================================================================

# Used by Celery broker, regime cache, rate-limit state, real-time dashboard.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=                 # set if Redis auth is enabled


# =====================================================================
# EXCHANGE APIs - Binance USD-M Futures
# =====================================================================

# Testnet keys (required during validation). Generate at:
#   https://testnet.binancefuture.com
BINANCE_FUTURES_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_FUTURES_TESTNET_API_SECRET=your_testnet_api_secret_here

# Mainnet keys - leave blank until live-trading readiness sign-off.
BINANCE_FUTURES_MAINNET_API_KEY=
BINANCE_FUTURES_MAINNET_API_SECRET=

# WebSocket base URLs (new paths per Binance 2026-04-23 migration).
BINANCE_WS_TESTNET_URL=wss://stream.binancefuture.com
BINANCE_WS_MAINNET_URL=wss://fstream.binance.com
BINANCE_WS_PUBLIC_PATH=/public
BINANCE_WS_MARKET_PATH=/market
BINANCE_WS_PRIVATE_PATH=/private


# =====================================================================
# EXCHANGE APIs - planned (not implemented)
# =====================================================================
# Placeholders so adapters can be added without env-var churn.
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_API_PASSPHRASE=
# HYPERLIQUID_API_KEY=
# HYPERLIQUID_API_SECRET=


# =====================================================================
# TELEGRAM ALERTS
# =====================================================================

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Recipient chat id (personal or group). Get yours from @userinfobot.
TELEGRAM_CHAT_ID=your_chat_id_here

# Alert verbosity: all | signals_only | critical_only
TELEGRAM_ALERT_LEVEL=signals_only


# =====================================================================
# NOTION (trade journal sync)
# =====================================================================

# Integration token: https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token_here

# Trade Journal database id (from the DB URL).
NOTION_TRADE_JOURNAL_DB_ID=

# Optional performance dashboard page id.
NOTION_DASHBOARD_PAGE_ID=


# =====================================================================
# WHALE ALERT (optional signal-filter input)
# =====================================================================
# Blank disables whale filtering (MockWhaleFilter is used).
WHALE_ALERT_KEY=


# =====================================================================
# OPENAI (optional - not used on the hot path)
# =====================================================================
# Reserved for offline research jobs. Keep blank unless a specific job
# needs it. See docs/decisions/adr-0003-llm-off-hot-path.md.
# OPENAI_API_KEY=


# =====================================================================
# RISK MANAGEMENT PARAMETERS
# =====================================================================
# Engine-wide invariants. See docs/risk/risk-framework.md.

# Daily equity-loss cap (%). Trading halts for the rest of the day.
MAX_DAILY_LOSS_PCT=5.0

# Consecutive-loss cool-off trigger.
MAX_CONSECUTIVE_LOSSES=3

# Peak-to-trough drawdown (%) at which all trading halts.
MAX_DRAWDOWN_PCT=10.0

# Concurrent-position ceiling.
MAX_OPEN_POSITIONS=5

# Portfolio "heat" cap (% of equity at risk across all open positions).
POSITION_HEAT_CAP_PCT=80

# Per-trade hard cap (%), Kelly ceiling.
PER_TRADE_HARD_CAP_PCT=2.0

# Maximum leverage the engine will request from the exchange.
MAX_LEVERAGE=10

# Starting account balance for equity and Kelly baseline calculations.
INITIAL_CAPITAL=10000.0


# =====================================================================
# SIGNAL AND SCORING THRESHOLDS
# =====================================================================

# Minimum confluence score to fire a signal (0..10 or 0..12 depending
# on scorer version). Higher = fewer, higher-conviction signals.
MIN_CONFLUENCE_SCORE=7.5

# Minimum HMM regime confidence (0..1). Below this, signals are suppressed.
MIN_REGIME_CONFIDENCE=0.55


# =====================================================================
# MARKET SCANNER
# =====================================================================

# Symbols to scan (comma-separated, Binance Futures format).
SCAN_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT,DOGE/USDT,AVAX/USDT,LINK/USDT

# Full-scan interval (seconds). 14400 = 4h; 3600 is the rate-limit floor.
SCAN_INTERVAL_SECONDS=14400

# Primary timeframe used by scanner + HMM.
SCAN_TIMEFRAME=4h

# OHLCV bars per pair per scan (300 @ 4h ~= 50 days of history).
OHLCV_LIMIT=300


# =====================================================================
# ALPHA DECAY MONITOR
# =====================================================================

ALPHA_DECAY_MIN_SHARPE=0.8
ALPHA_DECAY_WINDOW_DAYS=30


# =====================================================================
# SCALE-UP MANAGER
# =====================================================================

SCALE_UP_MIN_TRADES=20
SCALE_UP_MIN_SHARPE=1.2
SCALE_UP_STATE_FILE=scale_up_state.json


# =====================================================================
# WALK-FORWARD VALIDATION (used by /validate)
# =====================================================================

WFV_N_FOLDS=3
WFV_TRAIN_RATIO=0.70
WFV_MIN_SHARPE=0.8


# =====================================================================
# STRIPE BILLING (test mode during validation)
# =====================================================================
# Keys: https://dashboard.stripe.com/test/apikeys

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret from `stripe listen` or the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ids - create products in Stripe Dashboard then paste ids here.
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...
STRIPE_PRICE_ELITE_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...

# Redirect URLs. {CHECKOUT_SESSION_ID} is filled in by Stripe.
BILLING_SUCCESS_URL=http://localhost:8080/billing_success.html?session_id={CHECKOUT_SESSION_ID}
BILLING_CANCEL_URL=http://localhost:8080/pricing.html
BILLING_PORTAL_RETURN_URL=http://localhost:8080/account.html


# =====================================================================
# OBSERVABILITY / DEVOPS
# =====================================================================

# Prometheus `/metrics` endpoint toggle. Requires prometheus-client installed.
METRICS_ENABLED=false
METRICS_PORT=9090
