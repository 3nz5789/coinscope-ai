{
  "name": "coinscope-mcp-server",
  "version": "0.1.0",
  "description": "MCP server wrapping the CoinScopeAI Engine API (read-only + safe-trigger surface)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coinscope-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "coinscope",
    "crypto",
    "trading"
  ],
  "license": "UNLICENSED",
  "private": true
}
