# =============================================================================
#  CoinScopeAI — .gitignore
# =============================================================================

# ── Secrets & credentials ────────────────────────────────────────────────────
.env
*.pem
*.key
secrets/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker volumes & data ─────────────────────────────────────────────────────
redis_data/
prometheus_data/
grafana_data/

# ── Benchmark outputs ─────────────────────────────────────────────────────────
benchmark_results*.json

# ── ML model checkpoints ─────────────────────────────────────────────────────
*.pt
*.pth
*.onnx
checkpoints/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Celery ────────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid
