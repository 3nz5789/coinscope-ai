# =============================================================================
#  CoinScopeAI Trading Engine — Environment Template
#  ─────────────────────────────────────────────────────────────────────────
#  HOW TO USE:
#    1. Copy this file:   cp .env.example .env
#    2. Fill in your real values — NEVER commit .env to version control.
#    3. The engine validates all REQUIRED fields on startup.
#
#  LEGEND:
#    [REQUIRED] — must be set; engine refuses to start without it.
#    [OPTIONAL] — has a safe default; override when needed.
# =============================================================================


# ─── ENVIRONMENT ─────────────────────────────────────────────────────────────

# [REQUIRED] development | staging | production
ENV=development

# [OPTIONAL] Verbose debug logging (true/false)
DEBUG_MODE=false

# [OPTIONAL] Route traffic through Binance Testnet (true/false)
#            Keep true until you're ready to trade real funds.
TESTNET_MODE=true


# ─── BINANCE TESTNET ─────────────────────────────────────────────────────────
# Create testnet keys at: https://testnet.binancefuture.com

# [REQUIRED] Testnet API key
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here

# [REQUIRED] Testnet API secret
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# [OPTIONAL] Override only if Binance changes the URL
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com
BINANCE_TESTNET_WS_URL=wss://stream.binancefuture.com


# ─── BINANCE MAINNET ─────────────────────────────────────────────────────────
# Create keys at: https://www.binance.com/en/my/settings/api-management
# ⚠  Grant "Read" + "Futures Trading" ONLY — never grant "Withdrawal".

# [REQUIRED when TESTNET_MODE=false]
BINANCE_API_KEY=your_mainnet_api_key_here
BINANCE_API_SECRET=your_mainnet_api_secret_here

# [OPTIONAL]
BINANCE_BASE_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com


# ─── TELEGRAM ────────────────────────────────────────────────────────────────
# Get a bot token from @BotFather. Leave blank to disable (engine logs signals).

# [OPTIONAL] Token from @BotFather (format: 123456789:ABC-...)
TELEGRAM_BOT_TOKEN=

# [OPTIONAL] Chat / channel ID (e.g. -1001234567890)
TELEGRAM_CHAT_ID=

# [OPTIONAL] HTML | Markdown | MarkdownV2
TELEGRAM_PARSE_MODE=HTML

# [OPTIONAL] Send a startup message when the engine launches
TELEGRAM_SEND_STARTUP_MSG=false


# ─── REDIS ───────────────────────────────────────────────────────────────────

# [OPTIONAL] Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# [OPTIONAL] Cache TTL in seconds (default: 60)
REDIS_CACHE_TTL_SECONDS=60

# [OPTIONAL] Connection pool size (default: 10)
REDIS_POOL_SIZE=10


# ─── DATABASE ────────────────────────────────────────────────────────────────

# [OPTIONAL] SQLite for dev, PostgreSQL for production
#   SQLite:     sqlite:///./coinscope.db
#   PostgreSQL: postgresql+asyncpg://user:pass@host:5432/coinscope
DATABASE_URL=sqlite:///./coinscope.db

# [OPTIONAL]
DB_POOL_SIZE=5
DB_RESET_ON_STARTUP=false


# ─── RISK PARAMETERS ─────────────────────────────────────────────────────────

# [OPTIONAL] Halt trading if daily loss exceeds this % of equity (default: 2.0)
MAX_DAILY_LOSS_PCT=2.0

# [OPTIONAL] Maximum leverage per position (default: 10)
MAX_LEVERAGE=10

# Canonical max open positions: 5 (revised 2026-05-03 — supersedes earlier 3-cap)
MAX_OPEN_POSITIONS=5

# [OPTIONAL] Maximum per-position size as % of equity (default: 20.0)
MAX_SINGLE_POSITION_PCT=20.0

# [OPTIONAL] Maximum total portfolio exposure as % of equity (default: 80.0)
MAX_TOTAL_EXPOSURE_PCT=80.0

# [OPTIONAL] Minimum Risk:Reward before a signal is actioned (default: 1.5)
MIN_RISK_REWARD_RATIO=1.5

# [OPTIONAL] ATR period for volatility sizing (default: 14)
ATR_PERIOD=14


# ─── SCANNER ─────────────────────────────────────────────────────────────────

# [OPTIONAL] Pairs to scan (comma-separated Binance Futures symbols)
SCAN_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT

# [OPTIONAL] Scanner cycle interval in seconds (default: 5)
SCAN_INTERVAL_SECONDS=5

# [OPTIONAL] Volume spike multiplier vs rolling average (default: 3.0)
VOLUME_SPIKE_MULTIPLIER=3.0

# [OPTIONAL] Rolling window for volume baseline in candles (default: 20)
VOLUME_BASELINE_PERIOD=20

# [OPTIONAL] Funding rate deviation that triggers alert in % (default: 0.1)
FUNDING_RATE_THRESHOLD_PCT=0.1

# [OPTIONAL] Minimum confluence score (0–100) to emit a signal (default: 65)
MIN_CONFLUENCE_SCORE=65

# [OPTIONAL] Default candle interval: 1m | 5m | 15m | 1h | 4h | 1d
DEFAULT_TIMEFRAME=5m


# ─── ALERTS ──────────────────────────────────────────────────────────────────

# [OPTIONAL] Max alerts per minute (default: 10)
ALERT_RATE_LIMIT_PER_MIN=10

# [OPTIONAL] Minimum gap between duplicate signals for the same pair, in seconds
SIGNAL_COOLDOWN_SECONDS=300

# [OPTIONAL] Max in-memory alert queue size (default: 100)
ALERT_QUEUE_MAX_SIZE=100

# [OPTIONAL] Comma-separated webhook URLs (leave blank to disable)
WEBHOOK_URLS=


# ─── API SERVER ──────────────────────────────────────────────────────────────

# [OPTIONAL]
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# [OPTIONAL] CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# [OPTIONAL] JWT signing key — generate: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32


# ─── LOGGING ─────────────────────────────────────────────────────────────────

# [OPTIONAL] DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# [OPTIONAL] Log file path
LOG_FILE=logs/coinscope.log

# [OPTIONAL] Max log file size in MB before rotation
LOG_MAX_MB=10

# [OPTIONAL] Number of rotated log files to retain
LOG_BACKUP_COUNT=5
