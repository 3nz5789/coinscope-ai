# ─── CoinScopeAI — Binance Futures Configuration ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitignore).
#
# Get testnet keys from: https://testnet.binancefuture.com
# (log in with GitHub, click "Generate" under API Key)

# ── Environment ──────────────────────────────────────────────────────────────
# "true" = paper trading on testnet (safe, use this first)
# "false" = live trading on mainnet (real money!)
BINANCE_TESTNET=true

# ── API Credentials ───────────────────────────────────────────────────────────
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# ── Trade Parameters (all optional — these are the defaults) ─────────────────
RISK_PCT=1.0      # % of available balance to risk per trade (1.0 = 1%)
LEVERAGE=10       # futures leverage (1–125; start low on testnet)
SL_PCT=1.5        # stop-loss % distance from entry price
RR_RATIO=2.0      # reward:risk ratio  (TP distance = SL distance × RR_RATIO)
